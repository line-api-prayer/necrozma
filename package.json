{
  "name": "necrozma",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "SKIP_ENV_VALIDATION=true next build",
    "check": "next lint && tsc --noEmit",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "bun run build && next start",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun scripts/migrate.mjs",
    "db:seed": "bun scripts/seed.mjs"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.6.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.99.1",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/react-query": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "html5-qrcode": "^2.3.8",
    "next": "15.5.10",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.3.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.32.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.37",
    "@types/pdfmake": "^0.3.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.7",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vercel": "^50.32.5",
    "vitest": "^4.1.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "bun@1.3.8"
}
