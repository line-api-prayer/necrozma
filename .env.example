BETTER_AUTH_SECRET=

# LINE OAuth (for staff/admin login via LINE social auth)
# Get from: https://developers.line.biz/console/ → Line Login Channel
# Callback URL to whitelist: {BETTER_AUTH_URL}/api/auth/callback/line
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# LINE Messaging API (for customer notifications & daily reports)
# Get from: https://developers.line.biz/console/ → Messaging API Channel
LINE_ADMIN_BOT_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_BOT_CHANNEL_SECRET=
LINE_CUSTOMER_PROD_BOT_CHANNEL_ACCESS_TOKEN=
LINE_CUSTOMER_PROD_BOT_CHANNEL_SECRET=
LINE_CUSTOMER_TEST_BOT_CHANNEL_ACCESS_TOKEN=
LINE_CUSTOMER_TEST_BOT_CHANNEL_SECRET=

# LINE MyShop (OA Plus) API
# Get from: https://developers-oaplus.line.biz/
OA_PLUS_API_KEY=

# Application Config
ENABLE_TEST_MODE=false
ENABLE_SERVICE_REQUEST_PROMPTS=false
DEV_TEST_USER_ID=
ADMIN_LINE_UID=
CRON_SECRET=
